اشمل "Promises"؛

عرف مـؤجلات: لقب Promises؛
@دمج وحدة مـؤجلات {
    عرف مـؤجلة: لقب Promise؛
    @دمج صنف مـؤجلة {
        عرف النتيجة: لقب result؛
        عرف الحالة: لقب status؛
        عرف الخطأ: لقب error؛
        عرف قرر: لقب resolve؛
        عرف ارفض: لقب reject؛
        عرف أنشئ: لقب new؛
        عرف ثم: لقب then؛
        عرف اقبض: لقب catch؛
        عرف الكل: لقب all؛
        عرف تجاهل_النتيجة: لقب ignoreResult؛
    }

    عرف مـؤجلة_ثم: لقب ThenPromise؛
    @دمج صنف مـؤجلة_ثم {
        عرف أعد: لقب retry؛
    }

    عرف مـؤجلة_قبض: لقب CatchPromise؛
    @دمج صنف مـؤجلة_قبض {
        عرف أعد: لقب retry؛
    }

    صنف حـالة {
        عرف _جديد_: لقب Status.NEW؛
        عرف _مقرر_: لقب Status.RESOLVED؛
        عرف _مرفوض_: لقب Status.REJECTED؛
    }
}
